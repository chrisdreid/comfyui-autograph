          "input_ue_unconnectable": {}
        }
      },
      "widgets_values": [
        "Image will auto-save to the `ComfyUI/output` folder. You can also right-click on the `Save Image` node and then use the menu to save the image locally."
      ],
      "color": "#432",
      "bgcolor": "#000"
    },
    {
